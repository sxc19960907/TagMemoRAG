TAGMEMORAG__SERVER__HOST=0.0.0.0
TAGMEMORAG__SERVER__PORT=8000
TAGMEMORAG__SERVER__SHUTDOWN_TIMEOUT_SECONDS=60
TAGMEMORAG__LOGGING__LEVEL=INFO
TAGMEMORAG__LOGGING__FORMAT=json
TAGMEMORAG__MODEL__NAME=BAAI/bge-small-zh-v1.5
TAGMEMORAG__MODEL__PROVIDER=local
TAGMEMORAG__MODEL__DEVICE=cpu
TAGMEMORAG__MODEL__BASE_URL=https://api.siliconflow.cn/v1
TAGMEMORAG__MODEL__API_KEY_ENV=SILICONFLOW_API_KEY
TAGMEMORAG__STORAGE__DATA_DIR=/app/data
TAGMEMORAG__AUTH__ENABLED=false
TAGMEMORAG__RATE_LIMIT__DEFAULT_PER_MINUTE=60
TAGMEMORAG__CACHE__MAX_ENTRIES=10000
TAGMEMORAG__CACHE__TTL_SECONDS=3600
# For HTTP embeddings, set these in your deployment secret/env:
# TAGMEMORAG__MODEL__PROVIDER=http
# TAGMEMORAG__MODEL__NAME=Qwen/Qwen3-Embedding-8B
# TAGMEMORAG__MODEL__DIMENSIONS=4096
# SILICONFLOW_API_KEY=...
# For the local production-provider verification profile:
# DEEPSEEK_API_KEY=...
# TAGMEMORAG_S3_ACCESS_KEY=tagmemorag
# TAGMEMORAG_S3_SECRET_KEY=tagmemorag-secret
